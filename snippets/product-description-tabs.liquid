{% comment %} <div class="product-tabs-container">
  {%- assign desc = product.description -%}
  
  {%- comment -%} Identify if we use STYLE TIP or ATTRIBUTE {%- endcomment -%}
  {%- assign marker = "" -%}
  {%- if desc contains "STYLE TIP" -%}
    {%- assign marker = "STYLE TIP" -%}
  {%- elsif desc contains "ATTRIBUTE" -%}
    {%- assign marker = "ATTRIBUTE" -%}
  {%- endif -%}

  <div class="tabs-header">
    <button class="t-btn active" onclick="openCsTab(event, 'details')">Details</button>
    {% if marker != "" %}
      <button class="t-btn" onclick="openCsTab(event, 'extra')">{% if marker == "STYLE TIP" %}Style Tip{% else %}Attribute{% endif %}</button>
    {% endif %}
    {% if desc contains "SIZE AND FIT" %}
      <button class="t-btn" onclick="openCsTab(event, 'fit')">Size & Fit</button>
    {% endif %}
  </div>

  <div id="details" class="t-pane active">
    {%- if marker != "" -%}
      {{ desc | split: marker | first }}
    {%- elsif desc contains "SIZE AND FIT" -%}
      {{ desc | split: "SIZE AND FIT" | first }}
    {%- else -%}
      {{ desc }}
    {%- endif -%}
  </div>

  {% if marker != "" %}
    <div id="extra" class="t-pane">
      {%- assign extra_content = desc | split: marker | last -%}
      {%- if extra_content contains "SIZE AND FIT" -%}
        {{ extra_content | split: "SIZE AND FIT" | first }}
      {%- else -%}
        {{ extra_content }}
      {%- endif -%}
    </div>
  {% endif %}

  {% if desc contains "SIZE AND FIT" %}
    <div id="fit" class="t-pane">
      {{ desc | split: "SIZE AND FIT" | last }}
    </div>
  {% endif %}
</div>

<script>
function openCsTab(evt, tabId) {
  var i, panes, btns;
  panes = document.getElementsByClassName("t-pane");
  for (i = 0; i < panes.length; i++) { panes[i].classList.remove("active"); }
  btns = document.getElementsByClassName("t-btn");
  for (i = 0; i < btns.length; i++) { btns[i].classList.remove("active"); }
  document.getElementById(tabId).classList.add("active");
  evt.currentTarget.classList.add("active");
}
</script>

<style>
  .product-tabs-container { margin: 20px 0; border-top: 1px solid #e1e1e1; width: 100%; clear: both; }
  .tabs-header { display: flex; gap: 30px; border-bottom: 1px solid #e1e1e1; margin-bottom: 10px; }
  .t-btn { background: none; border: none; padding: 15px 0; cursor: pointer; font-size: 13px; font-weight: 700; text-transform: uppercase; color: #999; position: relative; }
  .t-btn.active { color: #000; }
  .t-btn.active::after { content: ""; position: absolute; bottom: -1px; left: 0; width: 100%; height: 2px; background: #000; }
  .t-pane { display: none; padding: 15px 0; line-height: 1.8; font-size: 14px; color: #333; }
  .t-pane.active { display: block; }
</style> {% endcomment %}




{% comment %} <div class="product-tabs-container" id="cs-tabs-wrapper">
  <div class="tabs-header" id="cs-tabs-nav">
    <button class="t-btn active" data-target="details">Details</button>
  </div>

  <div class="tabs-body" id="cs-tabs-body">
    <div id="tab-details" class="t-pane active">
      {{ product.description }}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('tab-details');
  const nav = document.getElementById('cs-tabs-nav');
  const body = document.getElementById('cs-tabs-body');
  
  if (!container) return;

  // We look for these markers regardless of HTML tags around them
  const markers = [
    { id: 'style', label: 'Style Tip', search: 'STYLE TIP' },
    { id: 'attr', label: 'Attribute', search: 'ATTRIBUTE' },
    { id: 'fit', label: 'Size & Fit', search: 'SIZE AND FIT' }
  ];

  let rawHTML = container.innerHTML;

  markers.forEach(item => {
    // This regex finds the word even if it's wrapped in <strong>, <b>, or <p>
    const regex = new RegExp(`(<[^>]*>\\s*${item.search}\\s*<\\/[^>]*>|${item.search})`, 'i');
    
    if (regex.test(rawHTML)) {
      const parts = rawHTML.split(regex);
      
      if (parts.length > 2) {
        // 1. Create the Button
        const btn = document.createElement('button');
        btn.className = 't-btn';
        btn.innerText = item.label;
        btn.setAttribute('data-target', item.id);
        nav.appendChild(btn);

        // 2. Create the Pane
        const pane = document.createElement('div');
        pane.className = 't-pane';
        pane.id = 'tab-' + item.id;
        pane.innerHTML = parts[parts.length - 1]; // Content after the marker
        body.appendChild(pane);

        // 3. Keep only the part BEFORE this marker for the Details tab
        rawHTML = parts[0];
      }
    }
  });

  // Update the Details tab with the remaining content
  container.innerHTML = rawHTML;

  // Click Event Logic
  nav.addEventListener('click', function(e) {
    if (!e.target.classList.contains('t-btn')) return;
    
    document.querySelectorAll('.t-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.t-pane').forEach(p => p.classList.remove('active'));
    
    e.target.classList.add('active');
    const target = e.target.getAttribute('data-target');
    const targetId = target === 'details' ? 'tab-details' : 'tab-' + target;
    document.getElementById(targetId).classList.add('active');
  });
});
</script>

<style>
  .product-tabs-container { margin: 25px 0; border-top: 1px solid #e1e1e1; width: 100%; clear: both; }
  .tabs-header { display: flex; gap: 35px; border-bottom: 1px solid #e1e1e1; margin-bottom: 10px; }
  .t-btn { 
    background: none; border: none; padding: 15px 0; cursor: pointer; 
    font-size: 13px; font-weight: 700; text-transform: uppercase; 
    color: #999; position: relative; letter-spacing: 1px; font-family: inherit;
  }
  .t-btn.active { color: #000; }
  .t-btn.active::after { 
    content: ""; position: absolute; bottom: -1px; left: 0; width: 100%; height: 2px; background: #000; 
  }
  .t-pane { display: none; padding: 20px 0; line-height: 1.8; font-size: 14px; color: #333; }
  .t-pane.active { display: block !important; }
  /* Hides the redundant headers inside the tabs for a clean look */
  .t-pane strong:first-child, .t-pane b:first-child { display: none !important; }
</style> {% endcomment %}



<div class="product-tabs-container" id="cs-tabs-wrapper">
