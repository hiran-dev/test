{%- comment -%}
  Automated Tab Splitter for RTW and Unstitched
  Handles: Details, Attribute/Style Tip, and Size & Fit
{%- endcomment -%}

{%- assign desc = product.description -%}

{%- comment -%} 1. Identify the second tab marker {%- endcomment -%}
{%- assign first_marker = blank -%}
{%- assign tab_2_label = blank -%}

{%- if desc contains '<strong>STYLE TIP</strong>' -%}
  {%- assign first_marker = '<strong>STYLE TIP</strong>' -%}
  {%- assign tab_2_label = 'Style Tip' -%}
{%- elsif desc contains '<strong>ATTRIBUTE</strong>' -%}
  {%- assign first_marker = '<strong>ATTRIBUTE</strong>' -%}
  {%- assign tab_2_label = 'Attribute' -%}
{%- endif -%}

{%- comment -%} 2. Identify the third tab marker {%- endcomment -%}
{%- assign second_marker = '<strong>SIZE AND FIT</strong>' -%}

{%- comment -%} 3. Perform the splits {%- endcomment -%}
{%- if first_marker != blank -%}
  {%- assign parts = desc | split: first_marker -%}
  {%- assign main_details = parts[0] -%}
  
  {%- if parts[1] contains second_marker -%}
    {%- assign sub_parts = parts[1] | split: second_marker -%}
    {%- assign mid_content = sub_parts[0] -%}
    {%- assign fit_content = sub_parts[1] -%}
  {%- else -%}
    {%- assign mid_content = parts[1] -%}
    {%- assign fit_content = blank -%}
  {%- endif -%}
{%- else -%}
  {%- comment -%} If no middle marker, check for just Size and Fit {%- endcomment -%}
  {%- if desc contains second_marker -%}
    {%- assign parts = desc | split: second_marker -%}
    {%- assign main_details = parts[0] -%}
    {%- assign mid_content = blank -%}
    {%- assign fit_content = parts[1] -%}
  {%- else -%}
    {%- assign main_details = desc -%}
    {%- assign mid_content = blank -%}
    {%- assign fit_content = blank -%}
  {%- endif -%}
{%- endif -%}

<div class="product-tabs-container">
  <div class="tabs-header">
    <button class="tab-btn active" data-target="details">Details</button>
    {% if mid_content != blank %}<button class="tab-btn" data-target="middle">{{ tab_2_label }}</button>{% endif %}
    {% if fit_content != blank %}<button class="tab-btn" data-target="fit">Size & Fit</button>{% endif %}
  </div>

  <div class="tabs-body">
    <div id="details" class="tab-pane active">{{ main_details }}</div>
    {% if mid_content != blank %}<div id="middle" class="tab-pane">{{ mid_content }}</div>{% endif %}
    {% if fit_content != blank %}<div id="fit" class="tab-pane">{{ fit_content }}</div>{% endif %}
  </div>
</div>

<style>
  .product-tabs-container { margin: 25px 0; border-top: 1px solid #eee; }
  .tabs-header { display: flex; gap: 25px; border-bottom: 1px solid #eee; overflow-x: auto; }
  .tab-btn { 
    background: none; border: none; padding: 12px 0; cursor: pointer; 
    font-size: 12px; font-weight: 600; text-transform: uppercase; 
    letter-spacing: 1px; color: #999; position: relative; white-space: nowrap;
  }
  .tab-btn.active { color: #000; }
  .tab-btn.active::after { 
    content: ""; position: absolute; bottom: -1px; left: 0; width: 100%; height: 2px; background: #000; 
  }
  .tab-pane { display: none; padding: 20px 0; font-size: 14px; line-height: 1.6; color: #444; }
  .tab-pane.active { display: block; animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const container = btn.closest('.product-tabs-container');
      container.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      container.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      
      btn.classList.add('active');
      container.querySelector(`#${btn.dataset.target}`).classList.add('active');
    });
  });
</script>