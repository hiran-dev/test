    border: none; 
    padding: 0;
    cursor: pointer; 
    font-size: 16px; 
    font-weight: 400; 
    text-transform: uppercase; 
    color: #333; 
    letter-spacing: 1px;
    display: flex;
    align-items: center;
  }

  /* Vertical separator style */
  .t-btn:not(:last-child)::after {
    content: "|";
    margin-left: 15px;
    color: #ccc;
    font-weight: 300;
  }

  .t-btn.active { 
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .t-pane { 
    display: none; 
    padding: 10px 0; 
    line-height: 1.6; 
    font-size: 14px; 
    color: #333; 
  }

  .t-pane.active { display: block !important; }

  /* Styling for headings like SHIRT, TROUSER, DUPATTA */
  .t-pane strong, .t-pane b {
    display: block;
    margin-top: 15px;
    margin-bottom: 5px;
    font-weight: 600;
    font-size: 15px;
  }

  .t-pane p {
    margin: 0 0 10px 0;
  }

  /* Reset first element spacing */
  .t-pane > *:first-child { 
    margin-top: 0 !important; 
  }
</style>