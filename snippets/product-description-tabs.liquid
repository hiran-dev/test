<div class="product-tabs-container">
  <div class="tabs-header" id="custom-tab-header">
    <button class="tab-btn active" data-tab="details">Details</button>
  </div>
  <div class="tabs-body" id="custom-tab-body">
    <div id="details-pane" class="tab-pane active">
      {{ product.description }}
    </div>
  </div>
</div>

<style>
  .product-tabs-container { margin: 20px 0; border-top: 1px solid #e1e1e1; font-family: inherit; }
  .tabs-header { display: flex; gap: 25px; border-bottom: 1px solid #e1e1e1; overflow-x: auto; }
  .tab-btn { 
    background: none; border: none; padding: 12px 0; cursor: pointer; 
    font-size: 13px; font-weight: 600; text-transform: uppercase; 
    letter-spacing: 1px; color: #999; position: relative; white-space: nowrap;
  }
  .tab-btn.active { color: #000; }
  .tab-btn.active::after { 
    content: ""; position: absolute; bottom: -1px; left: 0; width: 100%; height: 2px; background: #000; 
  }
  .tab-pane { display: none; padding: 20px 0; font-size: 14px; color: #333; line-height: 1.6; }
  .tab-pane.active { display: block; }
  /* Hide the headers inside the tabs to keep it clean */
  .tab-pane strong, .tab-pane b { display: block; margin-bottom: 5px; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const container = document.getElementById('details-pane');
  if (!container) return;

  const tabHeader = document.getElementById('custom-tab-header');
  const tabBody = document.getElementById('custom-tab-body');
  const markers = ["ATTRIBUTE", "STYLE TIP", "SIZE AND FIT"];
  
  let htmlContent = container.innerHTML;
  
  markers.forEach(marker => {
    // This regex looks for the word even if it's inside <strong> or <b> tags
    const regex = new RegExp(`(<br\\s*/?>\\s*)?(<(strong|b)>\\s*${marker}\\s*</(strong|b)>|${marker})`, 'i');
    
    if (regex.test(htmlContent)) {
      const parts = htmlContent.split(regex);
      
      if (parts.length > 1) {
        // 1. Create the Button
        const btn = document.createElement('button');
        btn.className = 'tab-btn';
        btn.innerText = marker === "ATTRIBUTE" ? "Attribute" : (marker === "STYLE TIP" ? "Style Tip" : "Size & Fit");
        btn.setAttribute('data-tab', marker.toLowerCase().replace(/\s/g, '-'));
        tabHeader.appendChild(btn);
        
        // 2. Create the Pane
        const pane = document.createElement('div');
        pane.className = 'tab-pane';
        pane.id = marker.toLowerCase().replace(/\s/g, '-');
        
        // The last part of the split is the content for this tab
        pane.innerHTML = parts[parts.length - 1];
        tabBody.appendChild(pane);
        
        // 3. Update the main content to remove what we just moved
        htmlContent = parts[0];
      }
    }
  });
  
  container.innerHTML = htmlContent;

  // Click functionality
  const allBtns = document.querySelectorAll('.tab-btn');
  const allPanes = document.querySelectorAll('.tab-pane');
  
  allBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      allBtns.forEach(b => b.classList.remove('active'));
      allPanes.forEach(p => p.classList.remove('active'));
      
      this.classList.add('active');
      const target = this.getAttribute('data-tab');
      document.getElementById(target === 'details' ? 'details-pane' : target).classList.add('active');
    });
  });
});
</script>