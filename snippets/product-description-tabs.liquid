<div class="product-tabs-wrapper">
  <div class="tabs-header-nav" id="customTabNav">
    <button class="tab-btn active" data-target="details">Details</button>
  </div>
  
  <div class="tabs-content-body" id="customTabBody">
    <div id="tab-details" class="tab-pane active">
      {{ product.description }}
    </div>
  </div>
</div>

<style>
  .product-tabs-wrapper { margin: 30px 0; border-top: 1px solid #eee; }
  .tabs-header-nav { display: flex; gap: 30px; border-bottom: 1px solid #eee; }
  .tab-btn { 
    background: none; border: none; padding: 15px 0; cursor: pointer; 
    font-size: 13px; font-weight: 600; text-transform: uppercase; 
    letter-spacing: 1px; color: #999; position: relative;
  }
  .tab-btn.active { color: #000; }
  .tab-btn.active::after { 
    content: ""; position: absolute; bottom: -1px; left: 0; width: 100%; height: 2px; background: #000; 
  }
  .tab-pane { display: none; padding: 20px 0; font-size: 14px; color: #333; line-height: 1.7; }
  .tab-pane.active { display: block !important; }
</style>

<script>
(function() {
  function initTabs() {
    const detailsPane = document.getElementById('tab-details');
    const nav = document.getElementById('customTabNav');
    const body = document.getElementById('customTabBody');
    if (!detailsPane || detailsPane.getAttribute('data-processed')) return;

    const markers = ["ATTRIBUTE", "STYLE TIP", "SIZE AND FIT"];
    let rawHtml = detailsPane.innerHTML;

    markers.forEach(marker => {
      // Regex to find markers even if they are nested in tags or have extra spaces
      const regex = new RegExp(`(<br.*?>\\s*|<div>\\s*|\\s*)?(<(strong|b|h3|h4)>\\s*${marker}\\s*</\\3>|${marker})`, 'i');
      
      if (regex.test(rawHtml)) {
        const parts = rawHtml.split(regex);
        if (parts.length > 3) {
          // Add Nav Button
          const btn = document.createElement('button');
          btn.className = 'tab-btn';
          btn.innerText = marker;
          btn.setAttribute('data-target', marker.replace(/\s+/g, '-').toLowerCase());
          nav.appendChild(btn);

          // Add Content Pane
          const pane = document.createElement('div');
          pane.className = 'tab-pane';
          pane.id = 'tab-' + marker.replace(/\s+/g, '-').toLowerCase();
          pane.innerHTML = parts[parts.length - 1];
          body.appendChild(pane);

          rawHtml = parts[0]; // Keep only the "before" part for the Details tab
        }
      }
    });

    detailsPane.innerHTML = rawHtml;
    detailsPane.setAttribute('data-processed', 'true');

    // Click Events
    nav.addEventListener('click', (e) => {
      if (!e.target.classList.contains('tab-btn')) return;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      e.target.classList.add('active');
      const targetId = 'tab-' + e.target.getAttribute('data-target');
      document.getElementById(targetId).classList.add('active');
    });
  }

  // This is the key: it watches for the description to load
  const observer = new MutationObserver((mutations) => {
    initTabs();
  });

  observer.observe(document.body, { childList: true, subtree: true });
  window.addEventListener('load', initTabs);
  initTabs();
})();
</script>