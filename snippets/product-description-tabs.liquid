<div class="product-tabs-container" id="ProductTabs">
  <div class="tabs-header" id="TabList">
    <button class="tab-btn active" data-target="details-pane">Details</button>
  </div>

  <div class="tabs-body" id="TabPanes">
    <div id="details-pane" class="tab-pane active">
      {{ product.description }}
    </div>
  </div>
</div>

<style>
  .product-tabs-container { margin: 30px 0; border-top: 1px solid #e1e1e1; }
  .tabs-header { display: flex; gap: 30px; border-bottom: 1px solid #e1e1e1; overflow-x: auto; }
  .tab-btn { 
    background: none; border: none; padding: 15px 0; cursor: pointer; 
    font-size: 13px; font-weight: 600; text-transform: uppercase; 
    letter-spacing: 1px; color: #999; position: relative; white-space: nowrap;
  }
  .tab-btn.active { color: #000; }
  .tab-btn.active::after { 
    content: ""; position: absolute; bottom: -1px; left: 0; width: 100%; height: 2px; background: #000; 
  }
  .tab-pane { display: none; padding: 20px 0; font-size: 14px; color: #333; line-height: 1.6; }
  .tab-pane.active { display: block; }
  .tab-pane strong:first-child { display: none; } /* Hides the repeated heading inside the tab */
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const descriptionContainer = document.getElementById('details-pane');
  const tabList = document.getElementById('TabList');
  const tabPanes = document.getElementById('TabPanes');
  
  // The keywords we are looking for
  const markers = ["ATTRIBUTE", "STYLE TIP", "SIZE AND FIT"];
  
  const content = descriptionContainer.innerHTML;
  let sections = [];
  
  // Logic to find markers and split content
  let lastIndex = 0;
  markers.forEach(marker => {
    // Check for marker in plain text or bold tags
    if (descriptionContainer.innerText.includes(marker)) {
      const regex = new RegExp(`(<[^>]*>)?${marker}(<[^>]*>)?`, 'i');
      const parts = descriptionContainer.innerHTML.split(regex);
      
      if (parts.length > 1) {
        // Create the Tab Button
        const btn = document.createElement('button');
        btn.className = 'tab-btn';
        btn.innerText = marker.toLowerCase();
        btn.style.textTransform = 'capitalize';
        btn.setAttribute('data-target', marker.replace(/\s+/g, '-').toLowerCase());
        tabList.appendChild(btn);
        
        // Create the Tab Pane
        const pane = document.createElement('div');
        pane.className = 'tab-pane';
        pane.id = marker.replace(/\s+/g, '-').toLowerCase();
        pane.innerHTML = parts[parts.length - 1];
        tabPanes.appendChild(pane);
        
        // Clean up the original details pane
        descriptionContainer.innerHTML = parts[0];
      }
    }
  });

  // Tab Switching Logic
  const allBtns = document.querySelectorAll('.tab-btn');
  const allPanes = document.querySelectorAll('.tab-pane');

  allBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      allBtns.forEach(b => b.classList.remove('active'));
      allPanes.forEach(p => p.classList.remove('active'));
      this.classList.add('active');
      document.getElementById(this.getAttribute('data-target')).classList.add('active');
    });
  });
});
</script>